# Compose env template for the Api/ stack. Copy to `.env` (gitignored) to override the defaults.
# These are DEV-ONLY placeholders (already documented across the repo) — never real secrets.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fintech_dev

# Host port the API is published on.
API_HOST_PORT=3000

# Dev-only auth secrets (>=16 chars to satisfy the API's fail-fast env validation).
JWT_ACCESS_SECRET=change-me-local-dev-only-min-16
JWT_REFRESH_SECRET=change-me-local-dev-only-min-16

# Allowed browser origins (Docker web proxy + host `ng serve` dev server).
CORS_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:8080
