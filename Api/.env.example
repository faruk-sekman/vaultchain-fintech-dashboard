# Api/ environment template — copy to `.env` (NEVER commit a real .env; see .gitignore).
# All values below are placeholders / safe defaults for local development only.

NODE_ENV=development
PORT=3000

# Reverse-proxy / load-balancer trust (audit O-9). Behind a proxy, set this so the
# real client IP is derived from a TRUSTED X-Forwarded-For (accurate per-IP throttling + audit ipHash).
# Unset/empty = trust nothing (no proxy assumed). Values: `true`, a hop count (e.g. `1`), or a
# CIDR / comma-separated trusted-proxy list. NEVER use `true` on the open internet (IP spoofing).
# TRUST_PROXY=1

# PostgreSQL 16. Local dev connection string — replace per environment.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fintech_dashboard?schema=public

# Auth secrets. Generate strong, unique values per environment (min 16 chars).
# These are NOT real secrets — they only document the required variables.
JWT_ACCESS_SECRET=change-me-local-dev-only-min-16
JWT_REFRESH_SECRET=change-me-local-dev-only-min-16

# Access-secret rotation (audit D-14). OPTIONAL: to rotate JWT_ACCESS_SECRET without
# logging everyone out, move the OLD secret here and set the NEW one above. Access tokens are SIGNED
# with JWT_ACCESS_SECRET and VERIFIED against current OR previous, so live sessions survive the
# rotation window; remove this once the old tokens have all expired (access TTL = 15m). Unset =
# current-secret-only (the default; unchanged behaviour). Min 16 chars when set.
# JWT_ACCESS_SECRET_PREVIOUS=

# Horizontal-scale readiness (audit D-14). OPTIONAL: when set, the rate-limiter and the
# realtime SSE bus use Redis so they work correctly across MULTIPLE instances behind a load balancer
# (shared per-IP throttle counters + cross-instance SSE fan-out). UNSET = in-memory throttler +
# single-process SSE — the default for local/CI/single-instance (no Redis required; behaviour
# unchanged). If Redis is unreachable at runtime the throttler DEGRADES to per-instance in-memory
# enforcement (never fail-open). No credentials are ever logged.
# PRODUCTION (NODE_ENV=production) requires rediss:// (TLS) OR an AUTH component (e.g.
# redis://:password@host) — the app fails fast at boot on a plaintext, unauthenticated prod URL.
# Dev/local example (plaintext OK in non-prod):
# REDIS_URL=redis://localhost:6379

# PII column-encryption master key: base64-encoded 32 bytes.
# Generate per environment, e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`.
# Leave UNSET for local dev to use the clearly-labeled dev-only fallback key (no confidentiality).
# REQUIRED in production — the app refuses to boot without it when NODE_ENV=production.
# FTD_PII_MASTER_KEY=
# FTD_PII_KEY_ID=env-v1

# MFA — opt-in TOTP + backup codes + remember-device.
# Placeholders / safe local-dev defaults only — NO real secrets here (TOTP secrets are per-user and
# generated at enrollment, never set via env). MFA stays OPT-IN: MFA_REQUIRED defaults false.
# Every MFA var is OPTIONAL with a safe default (the services fall back to the same values), so the
# app boots unconfigured in any environment — there is no prod fail-closed for MFA (unlike the PII key).
MFA_ISSUER=Fintech Dashboard (local-dev)
# RFC-6238 acceptance window in 30s steps (clock-skew tolerance); 1 = ±1 step.
MFA_TOTP_WINDOW=1
# Single-use challenge token lifetime, in seconds.
MFA_CHALLENGE_TTL=300
# Max bad-code attempts before a challenge fails closed.
MFA_MAX_VERIFY_ATTEMPTS=5
# Number of one-time backup recovery codes minted at enrollment.
MFA_BACKUP_CODE_COUNT=10
# Master switch for the optional "remember this device" path. CODE default is OFF (safe prod
# posture); local dev enables it so the opt-in checkbox on /mfa/verify actually works (A17).
MFA_REMEMBER_DEVICE_ENABLED=true
# Remembered-device trust-token lifetime, in seconds (here: 30 days).
MFA_REMEMBER_DEVICE_TTL=2592000
# Whether MFA is mandatory for sign-in (default false → opt-in seam to flip later).
MFA_REQUIRED=false

# Self-service password reset — MFA-gated, no email/JWT. Both optional.
PWRESET_CHALLENGE_TTL=300
PWRESET_MAX_ATTEMPTS=5
