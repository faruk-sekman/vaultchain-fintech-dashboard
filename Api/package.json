{
  "name": "fintech-dashboard-api",
  "version": "1.0.0",
  "private": true,
  "description": "Vaultchain fintech operations dashboard backend (NestJS 11 on Fastify + Prisma 7 + PostgreSQL)",
  "license": "MIT",
  "author": "Faruk Sekman",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "postinstall": "prisma generate",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "jest --passWithNoTests",
    "test:int": "jest --config jest-int.config.cjs --runInBand --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "openapi:generate": "ts-node scripts/generate-openapi.ts && openapi-typescript openapi.json -o src/generated/api-types.ts",
    "prisma:generate": "prisma generate",
    "prisma:integrity": "prisma db execute --file prisma/sql/integrity.sql",
    "prisma:security": "prisma db execute --file prisma/sql/db-security.sql",
    "prisma:format": "prisma format",
    "migrate:deploy": "node scripts/db-deploy.mjs",
    "migrate:dev": "prisma migrate dev",
    "migrate:status": "prisma migrate status",
    "migrate:reset": "prisma migrate reset --force"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/*.int-spec.ts",
      "!main.ts",
      "!**/*.module.ts",
      "!generated/**",
      "!**/index.ts",
      "!**/dto/*.ts",
      "!**/*.decorator.ts",
      "!common/auth/auth-principal.ts",
      "!common/crypto/envelope-encryptor.ts",
      "!modules/risk/screening/screening-provider.ts",
      "!modules/analytics/analytics.ddl.ts",
      "!modules/mfa/mfa.constants.ts",
      "!modules/password-reset/password-reset.constants.ts",
      "!infrastructure/prisma/prisma.service.ts"
    ],
    "coverageDirectory": "../coverage",
    "coverageReporters": [
      "text-summary",
      "json-summary",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 95,
        "lines": 95,
        "functions": 90,
        "branches": 92
      }
    },
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/../jest.setup.cjs"
    ]
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.0.3",
    "@nestjs/throttler": "^6.4.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.11.1",
    "nestjs-pino": "^4.4.0",
    "otplib": "^13.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "jest": "^30.4.2",
    "openapi-typescript": "^7.5.0",
    "prisma": "^7.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  }
}
