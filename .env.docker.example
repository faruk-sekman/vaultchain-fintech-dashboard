# Root compose env template (combined stack). Copy to `.env` (gitignored) to override.
# DEV-ONLY placeholders — never real secrets. The stack also starts with zero config (built-in defaults).

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fintech_dev

# Host ports.
API_HOST_PORT=3000
WEB_HOST_PORT=8080

# Dev-only auth secrets (>=16 chars to satisfy the API's fail-fast env validation).
JWT_ACCESS_SECRET=change-me-local-dev-only-min-16
JWT_REFRESH_SECRET=change-me-local-dev-only-min-16

# CORS allowlist. Covers the Docker web proxy (:8080) AND a host `ng serve` dev server (:4200/:4201).
CORS_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:8080
