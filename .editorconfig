# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,js,mjs,cjs,json,yml,yaml,scss,css,html}]
indent_style = space
indent_size = 2

# Trailing whitespace is significant in Markdown (hard line breaks).
[*.md]
trim_trailing_whitespace = false
